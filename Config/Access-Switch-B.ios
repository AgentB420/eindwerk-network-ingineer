!*******************************************************************************
!! Access-Switch-B
!!*******************************************************************************
enable
configure terminal

banner motd ^C
--------------------------
- Authorized access only -
--------------------------
^C

no ip domain-lookup
hostname Access-Switch-B

line console 0
 logging synchronous
exit

line vty 0 15
 logging synchronous
exit

vlan 40
 name SALES
vlan 99
 name NATIVE_VLAN
exit

interface vlan 40
 ip address 10.10.40.2 255.255.255.0
 no shutdown

ip default-gateway 10.10.40.254

interface gi0/1
 description TO-PC
 switchport mode access
 switchport access vlan 40
exit

interface gi0/0
 description TO-R-SITE-B
 switchport mode access
 switchport access vlan 40
exit
