
!*******************************************************************************
!! Access-Switch2
!!*******************************************************************************
enable
configure terminal

banner motd ^C
--------------------------
- Authorized access only -
--------------------------
^C

no ip domain-lookup
hostname Access-Switch2

line console 0
 logging synchronous
exit

line vty 0 15
 logging synchronous
exit

vlan 20
 name OFFICE
vlan 30
 name IT
vlan 99
 name NATIVE_VLAN
exit

! FIX: aparte interface vlan commando's ipv range
interface vlan 20
 no shutdown
exit
interface vlan 30
 no shutdown
exit

ip default-gateway 10.10.20.254

spanning-tree mode rapid-pvst
spanning-tree pathcost method long
spanning-tree portfast edge bpduguard default

interface gi0/0
 description END-DEVICES-OFFICE
 switchport mode access
 switchport access vlan 20
 spanning-tree portfast
 no shutdown
exit

interface gi0/1
 description END-DEVICES-IT
 switchport mode access
 switchport access vlan 30
 spanning-tree portfast
 no shutdown
exit

interface range gi1/1-2
 description UPLINK-TO-DISTRIBUTION-SWITCHES
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk allowed vlan 10,20,30,40,99
 switchport trunk native vlan 99
 no shutdown
exit

do write memory