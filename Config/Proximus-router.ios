!********************************************
!! PROXIMUS
!!********************************************
enable
configure terminal

banner motd ^C
--------------------------
- Authorized access only -
--------------------------
^C

no ip domain-lookup
ip routing
ipv6 unicast-routing
hostname PROXIMUS

enable secret cisco
service password-encryption

ip domain-name cisco.local
username admin secret cisco
crypto key generate rsa general-keys modulus 1024
ip ssh version 2

line console 0
 logging synchronous
exit

line vty 0 15
 login local
 transport input ssh
 exec-timeout 0 0
 logging synchronous
exit

interface gi0/0
 description LINK-TO-WAN
 ip address 10.255.1.6 255.255.255.252
 ipv6 address 2001:db8:2::2/64
 no shutdown
exit

interface gi0/1
 description LINK-TO-R-CORE-2
 ip address 10.255.0.6 255.255.255.252
 ipv6 address 2001:db8:20::2/64
 no shutdown
exit

interface gi0/2
 description LINK-TO-R-CORE-1
 ip address 10.255.0.13 255.255.255.252
 ipv6 address 2001:db8:13::1/64
 no shutdown
exit

router bgp 65003
 neighbor 10.255.1.5 remote-as 65000
 neighbor 10.255.0.5 remote-as 65001
 neighbor 10.255.0.14 remote-as 65001
 neighbor 2001:db8:2::1 remote-as 65000
 neighbor 2001:db8:20::1 remote-as 65001
 neighbor 2001:db8:13::2 remote-as 65001
 !network 10.255.0.4 mask 255.255.255.252
 !network 10.255.0.12 mask 255.255.255.252
 !network 10.255.1.4 mask 255.255.255.252
 address-family ipv4
  neighbor 10.255.1.5 activate
  neighbor 10.255.0.5 activate
  neighbor 10.255.0.14 activate
 exit-address-family

 address-family ipv6
  neighbor 2001:db8:2::1 activate
  neighbor 2001:db8:20::1 activate
  neighbor 2001:db8:13::2 activate
 exit-address-family
exit

!!statische route naar internet gaaat via BGP peer (WAN-ROUTER) - geen noodzaak voor extra statische route
!ip route 0.0.0.0 0.0.0.0 10.255.1.5

do write memory