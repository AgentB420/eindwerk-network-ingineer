!*********************************************
!! R-CORE-1
!!********************************************
enable
configure terminal

banner motd ^C
--------------------------
- Authorized access only -
--------------------------
^C

no ip domain-lookup
ip routing
ipv6 unicast-routing
hostname R-CORE-1

enable secret cisco
service password-encryption

ip domain-name cisco.local
username admin secret cisco
crypto key generate rsa general-keys modulus 1024
ip ssh version 2

line console 0
 logging synchronous
exit

line vty 0 15
 login local
 transport input ssh
 exec-timeout 0 0
 logging synchronous
exit

interface gi0/0
 description LINK-TO-TELENET
 ip address 10.255.0.1 255.255.255.252
 ipv6 address 2001:db8:10::1/64
 no shutdown
exit

! link naar Proximus 
interface gi0/2
 description LINK-TO-PROXIMUS
 ip address 10.255.0.14 255.255.255.252
 ipv6 address 2001:db8:13::2/64
 no shutdown
exit

interface gi0/3
description LINK-TO-R-CORE-2
 ip address 10.0.0.1 255.255.255.252
 ipv6 address 2001:db8:0:1::1/64
 ospfv3 1 ipv4 area 0
 ospfv3 1 ipv6 area 0
 ospfv3 1 network point-to-point
 no shutdown

interface gi0/1
description LINK-TO-DISTRI-SW1
 ip address 10.0.0.5 255.255.255.252
 ipv6 address 2001:db8:0:2::1/64
 ospfv3 1 ipv4 area 0
 ospfv3 1 ipv6 area 0
 ospfv3 1 network point-to-point
 no shutdown
exit

!IPv6 + OSPFv3 configuratie met ipv4 en ipv6 in hetzelfde OSPFv3 proces

router ospfv3 1
 router-id 1.1.1.1

 address-family ipv4 unicast
  passive-interface default
  no passive-interface gi0/3
  no passive-interface gi0/1
  default-information originate always
  redistribute bgp 65001 
 exit-address-family

 address-family ipv6 unicast
  passive-interface default
  no passive-interface gi0/3
  no passive-interface gi0/1
  default-information originate always
  redistribute bgp 65001
 exit-address-family
exit

!BGP configuratie 
router bgp 65001
 neighbor 10.255.0.2 remote-as 65002
 neighbor 10.255.0.13 remote-as 65003
 neighbor 2001:db8:10::2 remote-as 65002
 neighbor 2001:db8:13::1 remote-as 65003
! network 10.10.0.0 mask 255.255.0.0
! redistribute ospf 1 

address-family ipv4
  neighbor 10.255.0.2 activate
  neighbor 10.255.0.13 activate
  network 10.10.0.0 mask 255.255.0.0
  redistribute ospfv3 1 
 exit-address-family

 address-family ipv6
  neighbor 2001:db8:10::2 activate
  neighbor 2001:db8:13::1 activate
  network 2001:db8::/32
  redistribute ospfv3 1
 exit-address-family
exit

do write memory