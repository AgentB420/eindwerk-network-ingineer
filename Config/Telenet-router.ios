!********************************************
!! TELENET
!!********************************************
enable
configure terminal

banner motd ^C
--------------------------
- Authorized access only -
--------------------------
^C

no ip domain-lookup
ip routing
ipv6 unicast-routing
hostname TELENET

enable secret cisco
service password-encryption

ip domain-name cisco.local
username admin secret cisco
crypto key generate rsa general-keys modulus 1024
ip ssh version 2

line console 0
 logging synchronous
exit

line vty 0 15
 login local
 transport input ssh
 exec-timeout 0 0
 logging synchronous
exit

interface gi0/0
 description LINK-TO-WAN
 ip address 10.255.1.2 255.255.255.252
 ipv6 address 2001:db8:1::2/64
 no shutdown
exit

interface gi0/1
 description LINK-TO-R-CORE-1
 ip address 10.255.0.2 255.255.255.252
 ipv6 address 2001:db8:10::2/64
 no shutdown
exit

interface gi0/2
 description LINK-TO-R-CORE-2
 ip address 10.255.0.9 255.255.255.252
 ipv6 address 2001:db8:12::1/64
 no shutdown
exit

router bgp 65002
 neighbor 10.255.1.1 remote-as 65000
 neighbor 10.255.0.1 remote-as 65001
 neighbor 10.255.0.10 remote-as 65001
 neighbor 2001:db8:1::1 remote-as 65000
 neighbor 2001:db8:10::1 remote-as 65001
 neighbor 2001:db8:12::2 remote-as 65001
 !network 10.255.0.0 mask 255.255.255.252
 !network 10.255.0.8 mask 255.255.255.252
 !network 10.255.1.0 mask 255.255.255.252
 address-family ipv4
  neighbor 10.255.1.1 activate
  neighbor 10.255.0.1 activate
  neighbor 10.255.0.10 activate
 exit-address-family

 address-family ipv6
  neighbor 2001:db8:1::1 activate
  neighbor 2001:db8:10::1 activate
  neighbor 2001:db8:12::2 activate
 exit-address-family
exit


!!statische route naar internet gaaat via BGP peer (WAN-ROUTER) - geen noodzaak voor extra statische route
!ip route 0.0.0.0 0.0.0.0 10.255.1.1

do write memory