!*******************************************************************************
!! Distri-Switch1
!!*******************************************************************************
enable
configure terminal

banner motd ^C
--------------------------
- Authorized access only -
--------------------------
^C

no ip domain-lookup
ip routing
ipv6 unicast-routing
hostname Distri-Switch1

enable secret cisco
service password-encryption

ip domain-name cisco.local
username admin secret cisco
crypto key generate rsa general-keys modulus 1024
ip ssh version 2

line console 0
 logging synchronous
exit

line vty 0 15
 login local
 transport input ssh
 exec-timeout 0 0
 logging synchronous
exit

vlan 10
 name MGMT
vlan 20
 name OFFICE
vlan 30
 name IT
vlan 40
 name SALES
vlan 99
 name NATIVE_VLAN
exit

!  HSRP  - SW1 actief voor VLAN10,20 | SW2 actief voor VLAN30,40
interface vlan 10
 description GATEWAY-MGMT
 ip address 10.10.10.2 255.255.255.0
 standby version 2
 standby 10 ip 10.10.10.254
 standby 10 priority 110
 standby 10 preempt
 standby 10 timers 1 3
 no shutdown
exit

interface vlan 20
 description GATEWAY-OFFICE
 ip address 10.10.20.2 255.255.255.0
 standby version 2
 standby 20 ip 10.10.20.254
 standby 20 priority 110
 standby 20 preempt
 standby 20 timers 1 3
 no shutdown
exit

interface vlan 30
 description GATEWAY-IT
 ip address 10.10.30.2 255.255.255.0
 standby version 2
 standby 30 ip 10.10.30.254
 standby 30 priority 90
 standby 30 preempt
 standby 30 timers 1 3
 no shutdown
exit

interface vlan 40
 description GATEWAY-SALES
 ip address 10.10.40.2 255.255.255.0
 standby version 2
 standby 40 ip 10.10.40.254
 standby 40 priority 90
 standby 40 preempt
 standby 40 timers 1 3
 no shutdown
exit

spanning-tree mode rapid-pvst
spanning-tree pathcost method long
spanning-tree portfast edge bpduguard default
spanning-tree vlan 10,20 priority 8192
spanning-tree vlan 30,40 priority 16384

interface range gi0/1-2
 channel-group 10 mode active
exit

interface port-channel 10
 description LACP-LINK-TO-DISTRI-SW-2
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport nonegotiate
 switchport trunk allowed vlan 10,20,30,40,99
 switchport trunk native vlan 99
 no shutdown
exit

interface range gi1/0-2
 description LINK-TO-ACCESS-SWITCHES
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk allowed vlan 10,20,30,40,99
 switchport trunk native vlan 99
 no shutdown
exit

interface gi0/0
description LINK-TO-R-CORE-1
 no switchport
 ip address 10.0.0.6 255.255.255.252
 ipv6 address 2001:db8:0:2::2/64
 ospfv3 1 ipv4 area 0
 ospfv3 1 ipv6 area 0
 ospfv3 network point-to-point
 no shutdown

interface vlan 10
 ip address 10.10.10.2 255.255.255.0
 ipv6 address 2001:db8:10::1/64
 ospfv3 1 ipv4 area 0
 ospfv3 1 ipv6 area 0

interface vlan 20
 ip address 10.10.20.2 255.255.255.0
 ipv6 address 2001:db8:20::1/64
 ospfv3 1 ipv4 area 0
 ospfv3 1 ipv6 area 0

interface vlan 30
 ip address 10.10.30.2 255.255.255.0
 ipv6 address 2001:db8:30::1/64
 ospfv3 1 ipv4 area 0
 ospfv3 1 ipv6 area 0

interface vlan 40
 ip address 10.10.40.2 255.255.255.0
 ipv6 address 2001:db8:40::1/64
 ospfv3 1 ipv4 area 0
 ospfv3 1 ipv6 area 0

!IPV6 + OSPFv3 configuratie met ipv4 en ipv6 in hetzelfde OSPFv3 proces
router ospfv3 1
 router-id 10.10.10.1

 address-family ipv4 unicast
  passive-interface default
  no passive-interface gi0/0
 exit-address-family

 address-family ipv6 unicast
  passive-interface default
  no passive-interface gi0/0
  no passive-interface vlan 10
  no passive-interface vlan 20
  no passive-interface vlan 30
  no passive-interface vlan 40
 exit-address-family
exit

do write memory


